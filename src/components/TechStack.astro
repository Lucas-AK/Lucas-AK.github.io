---
interface TechItem {
  name: string;
  symbol: string;
  icon?: string; // Optional devicon class
}

interface Props {
  techStack: TechItem[];
}

const { techStack } = Astro.props;
---

<section>
  <h2>Technologies</h2>
  <ul class="tech-list">
    {techStack.map(tech => (
      <li>
        {tech.icon ? (
          <i class={tech.icon}></i>
        ) : (
          <span>{tech.symbol}</span>
        )}
        {' '}{tech.name}
      </li>
    ))}
  </ul>
</section>

<style>
  .tech-list {
    display: grid;
    grid-template-rows: repeat(3, auto);
    grid-auto-flow: column;
    grid-auto-columns: max-content;
    gap: 4px 32px;
    list-style: none;
    padding: 0;
    margin: 8px 0;
  }

  @media (max-width: 680px) {
    .tech-list {
      grid-template-rows: none;
      grid-auto-flow: row;
      grid-auto-columns: auto;
      gap: 4px;
    }
  }
</style>
